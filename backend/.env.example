# MongoDB connection string
MONGODB_URL=
# MongoDB database name
MONGODB_DB_NAME=
# JWT secret key
JWT_SECRET=
# JWT algorithm (default: HS256)
JWT_ALGORITHM=HS256
# Access token expiration (minutes)
ACCESS_TOKEN_EXPIRE_MINUTES=15
# Refresh token expiration (days)
REFRESH_TOKEN_EXPIRE_DAYS=7
# Groq API key for LLM/Whisper
GROQ_API_KEY=
# Gemini API key for Google LLM (optional)
GEMINI_API_KEY=
# LLM provider: 'groq' or 'gemini'
LLM_PROVIDER=groq
# Allowed frontend URL for CORS
FRONTEND_URL=http://localhost:5173
# Debug mode
DEBUG=true
# Whisper model name
AUDIO_MODEL=whisper-large-v3-turbo
# Path to ffmpeg executable
AUDIO_FFMPEG_PATH=
# Max audio upload size (bytes)
AUDIO_MAX_UPLOAD_BYTES=8000000
# Max audio duration (seconds)
AUDIO_MAX_DURATION_SECONDS=300
# ffmpeg conversion timeout (seconds)
AUDIO_CONVERSION_TIMEOUT_SECONDS=20
# Transcription provider timeout (seconds)
AUDIO_PROVIDER_TIMEOUT_SECONDS=30